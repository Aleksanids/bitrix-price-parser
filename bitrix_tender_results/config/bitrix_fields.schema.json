{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bitrix24 Tender Result Three-Field Mapping",
  "type": "object",
  "additionalProperties": false,
  "required": ["portal", "entityTypeId", "categoryId", "fields", "automation"],
  "properties": {
    "portal": {
      "type": "string",
      "minLength": 1
    },
    "entityTypeId": {
      "type": "integer",
      "const": 2
    },
    "categoryId": {
      "type": "integer",
      "minimum": 0
    },
    "fields": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "winner_name_analytics",
        "winner_price_analytics",
        "participants_count_analytics"
      ],
      "properties": {
        "winner_name_analytics": {"type": "string"},
        "winner_price_analytics": {"type": "string"},
        "participants_count_analytics": {"type": "string"}
      }
    },
    "automation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_mode",
        "allow_overwrite_default"
      ],
      "properties": {
        "default_mode": {"type": "string", "enum": ["dry_run", "update"]},
        "allow_overwrite_default": {"type": "boolean"}
      }
    }
  }
}
